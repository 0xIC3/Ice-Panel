# Copy to `.env.production` and fill in. Used by `docker-compose.prod.yml`.
#
#   cp .env.production.example .env.production
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# ───── Postgres ─────
# Used both by the postgres container and assembled into DATABASE_URL.
POSTGRES_USER=icepanel
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=icepanel

# ───── Backend ─────

# DATABASE_URL points at the postgres service over the compose network.
# Use the values you set above for user/password/db.
DATABASE_URL=postgres://icepanel:CHANGE_ME_STRONG_PASSWORD@postgres:5432/icepanel

# REDIS_URL points at the redis service over the compose network.
REDIS_URL=redis://redis:6379

# JWT_SECRET MUST be at least 32 chars. Generate with:
#   openssl rand -base64 48 | tr -d '\n'
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_random_string

# Token lifetime — default 24h is fine.
JWT_EXPIRES_IN=24h

# Production: set to fatal/error/warn. Dev/diagnostics: info/debug.
LOG_LEVEL=info

# Comma-separated list of frontend origins allowed to call /api directly.
# When the panel is fronted by the bundled frontend nginx (same origin),
# CORS does not apply. Keep this empty (or set to your public URL) and
# put both panel and frontend behind a reverse proxy.
CORS_ORIGIN=https://panel.example.com

# Public Hysteria 2 UDP port advertised in subscription URIs.
# Default 443 — every node operator should run hysteria on :443/UDP.
HYSTERIA_PUBLIC_PORT=443

# ───── Frontend ─────

# Empty = relative requests that the frontend's nginx proxies to backend.
# Set explicitly only if you serve the frontend from a different origin
# than the backend (uncommon).
VITE_API_BASE_URL=

# Host port the frontend listens on (mapped to container :80).
# Behind Traefik/Caddy/nginx-on-host, leave at 8080 and reverse-proxy to it.
FRONTEND_PORT=8080
