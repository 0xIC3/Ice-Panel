      "type": "stat",
      "title": "Users by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (ice_panel_users)",
