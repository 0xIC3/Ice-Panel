// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String    @id @default(uuid()) @db.Uuid
  username     String    @unique @db.VarChar(64)
  passwordHash String    @map("password_hash") @db.VarChar(128)
  role         String    @default("admin") @db.VarChar(32)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  performedEvents SubscriptionEvent[]

  @@map("admin_users")
}

model ApiToken {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @db.VarChar(64)
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  scopes     Json      @default("[]")
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("api_tokens")
}

// Singleton holding the panel's self-signed CA used to issue per-node mTLS
// certificates. Always exactly one row (id = 1) — bootstrap on first start.
model KeygenCa {
  id            Int      @id @default(1)
  certPem       String   @map("cert_pem")
  privateKeyPem String   @map("private_key_pem")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("keygen_ca")
}

model Node {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String    @unique @db.VarChar(64)
  address               String    @unique @db.VarChar(255)
  publicKey             Bytes?    @map("public_key")
  countryCode           String?   @map("country_code") @db.Char(2)
  status                String    @default("unknown") @db.VarChar(16)
  lastStatusChange      DateTime? @map("last_status_change") @db.Timestamptz(6)
  lastStatusMessage     String?   @map("last_status_message")
  consumptionMultiplier BigInt    @default(1) @map("consumption_multiplier")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz(6)

  inbounds Inbound[]
  connectedUsers  UserTraffic[]
  userUsageHistory NodeUserUsageHistory[]
  usageHistory     NodeUsageHistory[]

  @@index([status])
  @@index([deletedAt])
  @@map("nodes")
}

model Inbound {
  id        String   @id @default(uuid()) @db.Uuid
  nodeId    String   @map("node_id") @db.Uuid
  protocol  String   @db.VarChar(32)
  name      String   @db.VarChar(64)
  port      Int
  config    Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  node Node @relation(fields: [nodeId], references: [id], onDelete: Restrict)
  groupInbounds GroupInbound[]
  amneziawgPeers AmneziawgPeer[]

  @@unique([nodeId, port])
  @@index([nodeId])
  @@index([protocol])
  @@map("inbounds")
}

model Group {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(64)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  groupInbounds GroupInbound[]
  members       GroupMember[]

  @@map("groups")
}

model GroupInbound {
  groupId   String   @map("group_id") @db.Uuid
  inboundId String   @map("inbound_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inbound Inbound @relation(fields: [inboundId], references: [id], onDelete: Cascade)

  @@id([groupId, inboundId])
  @@index([inboundId])
  @@map("group_inbounds")
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  shortId  String @unique @map("short_id") @db.VarChar(16)
  username String @db.VarChar(64)
  status   String @default("active") @db.VarChar(16)

  // Subscription window
  expireAt DateTime? @map("expire_at") @db.Timestamptz(6)

  // Traffic
  trafficLimitBytes    BigInt? @map("traffic_limit_bytes")
  trafficLimitStrategy String  @default("no_reset") @map("traffic_limit_strategy") @db.VarChar(16)

  // Subscription URL
  subscriptionToken String    @unique @map("subscription_token") @db.VarChar(64)
  subRevokedAt      DateTime? @map("sub_revoked_at") @db.Timestamptz(6)

  // Pre-generated credentials for all protocols
  hysteriaPassword    String @map("hysteria_password") @db.VarChar(64)
  amneziawgPrivateKey String @map("amneziawg_private_key") @db.VarChar(64)
  amneziawgPublicKey  String @map("amneziawg_public_key") @db.VarChar(64)
  naivePassword       String @map("naive_password") @db.VarChar(64)
  xrayUuid            String @map("xray_uuid") @db.Uuid

  // Per-user enabled protocols (subset of {hysteria, xray, amneziawg, naive}).
  // Subscription generator filters endpoints by this; default keeps existing
  // users on hysteria-only and admins explicitly opt in to others.
  enabledProtocols Json @default("[\"hysteria\"]") @map("enabled_protocols")

  // Limits
  hwidDeviceLimit Int? @map("hwid_device_limit")

  // Metadata (admin-facing)
  description String?
  tag         String? @db.VarChar(64)
  telegramId  BigInt? @map("telegram_id")
  email       String? @db.VarChar(255)

  // Lifecycle
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Relations
  traffic      UserTraffic?
  groupMembers GroupMember[]
  events               SubscriptionEvent[]
  subscriptionRequests SubscriptionRequestHistory[]
  nodeUsageHistory     NodeUserUsageHistory[]
  amneziawgPeers       AmneziawgPeer[]

  @@index([username])
  @@index([status])
  @@index([expireAt])
  @@index([deletedAt])
  @@index([telegramId])
  @@index([email])
  @@map("users")
}

model UserTraffic {
  userId               String    @id @map("user_id") @db.Uuid
  usedTrafficBytes     BigInt    @default(0) @map("used_traffic_bytes")
  lifetimeTrafficBytes BigInt    @default(0) @map("lifetime_traffic_bytes")
  onlineAt             DateTime? @map("online_at") @db.Timestamptz(6)
  firstConnectedAt     DateTime? @map("first_connected_at") @db.Timestamptz(6)
  lastConnectedNodeId  String?   @map("last_connected_node_id") @db.Uuid
  lastTrafficResetAt   DateTime? @map("last_traffic_reset_at") @db.Timestamptz(6)

  user              User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastConnectedNode Node? @relation(fields: [lastConnectedNodeId], references: [id], onDelete: SetNull)

  @@index([lastConnectedNodeId])
  @@index([onlineAt])
  @@map("user_traffic")
}

model GroupMember {
  groupId   String   @map("group_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

model SubscriptionEvent {
  id                 BigInt    @id @default(autoincrement())
  userId             String    @map("user_id") @db.Uuid
  eventType          String    @map("event_type") @db.VarChar(32)
  performedByAdminId String?   @map("performed_by_admin_id") @db.Uuid

  // State snapshot (before/after)
  trafficLimitBefore BigInt?   @map("traffic_limit_before")
  trafficLimitAfter  BigInt?   @map("traffic_limit_after")
  trafficUsedBefore  BigInt?   @map("traffic_used_before")
  trafficUsedAfter   BigInt?   @map("traffic_used_after")
  expireAtBefore     DateTime? @map("expire_at_before") @db.Timestamptz(6)
  expireAtAfter      DateTime? @map("expire_at_after") @db.Timestamptz(6)
  statusBefore       String?   @map("status_before") @db.VarChar(16)
  statusAfter        String?   @map("status_after") @db.VarChar(16)

  reason    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  performedByAdmin AdminUser? @relation(fields: [performedByAdminId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType])
  @@map("subscription_events")
}

// Per-user IP allocation for AmneziaWG inbounds. One row per (inboundId, userId);
// allocator picks the first free IP from the inbound's subnet (default 10.0.0.0/24).
// Persisted so the same user keeps a stable IP across restarts and so we can detect
// IP exhaustion before mutating the awg config.
model AmneziawgPeer {
  id        String   @id @default(uuid()) @db.Uuid
  inboundId String   @map("inbound_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  ip        String   @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  inbound Inbound @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([inboundId, ip])
  @@unique([inboundId, userId])
  @@index([userId])
  @@map("amneziawg_peers")
}

model SubscriptionRequestHistory {
  id          BigInt   @id @default(autoincrement())
  userId      String   @map("user_id") @db.Uuid
  requestIp   String?  @map("request_ip") @db.VarChar(45)
  userAgent   String?  @map("user_agent")
  requestedAt DateTime @default(now()) @map("requested_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, requestedAt(sort: Desc)])
  @@map("subscription_request_history")
}

model NodeUserUsageHistory {
  nodeId   String   @map("node_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  date     DateTime @db.Date
  bytesIn  BigInt   @default(0) @map("bytes_in")
  bytesOut BigInt   @default(0) @map("bytes_out")

  node Node @relation(fields: [nodeId], references: [id], onDelete: Restrict)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([nodeId, date, userId])
  @@index([userId, date(sort: Desc)])
  @@map("node_user_usage_history")
}

model NodeUsageHistory {
  nodeId        String   @map("node_id") @db.Uuid
  hour          DateTime @map("hour") @db.Timestamptz(6)
  downloadBytes BigInt   @default(0) @map("download_bytes")
  uploadBytes   BigInt   @default(0) @map("upload_bytes")

  node Node @relation(fields: [nodeId], references: [id], onDelete: Restrict)

  @@id([nodeId, hour])
  @@index([nodeId, hour(sort: Desc)])
  @@map("node_usage_history")
}