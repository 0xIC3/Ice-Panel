# Copy to `.env.production` and fill in. Used by `docker-compose.prod.yml`.
#
#   cp .env.production.example .env.production
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# Generated values (JWT_SECRET, POSTGRES_PASSWORD): use openssl.
#   openssl rand -base64 48 | tr -d '\n'

# ============================================================================
# REQUIRED — without these the panel won't start
# ============================================================================

# ───── Postgres ─────
POSTGRES_USER=icepanel
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=icepanel

DATABASE_URL=postgres://icepanel:CHANGE_ME_STRONG_PASSWORD@postgres:5432/icepanel

# ───── Redis ─────
REDIS_URL=redis://redis:6379

# ───── Auth ─────
# Must be ≥32 chars. Generate: openssl rand -base64 48 | tr -d '\n'
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_random_string
JWT_EXPIRES_IN=24h

# ───── Public surface ─────
# Public base URL of this panel (no trailing slash). REQUIRED — used to
# generate bootstrap install commands, subscription links, and the
# panelUrl baked into node payloads (heartbeat self-destruct depends on it).
PUBLIC_URL=https://panel.example.com

# Comma-separated list of frontend origins allowed to call /api directly.
# When SPA is served from the same origin as the API (default deploy), set
# to PUBLIC_URL.
CORS_ORIGIN=https://panel.example.com

# Public Hysteria 2 UDP port advertised in subscription URIs.
HYSTERIA_PUBLIC_PORT=443

LOG_LEVEL=info

# ============================================================================
# Security (cycle #5 S6/S7 + cycle #6 Tier-1) — set these in prod
# ============================================================================

# Trusted reverse-proxy hops in front of the backend.
#   0 = behind nothing (don't trust X-Forwarded-For — dev / single-host)
#   1 = behind one proxy (Caddy / nginx on same host)
#   2 = behind two proxies (Cloudflare → Caddy → backend). RECOMMENDED.
# Bumping this above the real hop count lets attackers spoof X-Forwarded-For
# and bypass per-IP rate limits.
TRUST_PROXY_HOPS=2

# This panel's public egress IP. Baked into node-install commands as
# --panel-ip so each node's UFW only opens :8443/tcp to THIS IP.
# Auto-detection at runtime via ipify falls back when this is unset.
PANEL_PUBLIC_IP=

# Per-route rate limits (per minute, per IP). Defaults are tuned for a
# small-mid panel; raise for busy multi-thousand-user instances.
RATE_LIMIT_SUB_PER_MIN=30
RATE_LIMIT_BOOTSTRAP_PER_MIN=10
RATE_LIMIT_HEARTBEAT_PER_MIN=120

# Username lockout (Redis-backed, S7 cycle #5).
LOGIN_LOCKOUT_FAILURES=5
LOGIN_LOCKOUT_DURATION_MIN=15
LOGIN_LOCKOUT_WINDOW_MIN=15

# ACME contact email — auto-injected into Hysteria / Naive node-install
# commands. Optional but recommended (UI emits a placeholder otherwise).
ACME_DEFAULT_EMAIL=admin@example.com

# ───── Tier-1: Telegram alerts (cycle #6) ─────
# Set both to enable login / lockout / honeypot / node-flip / user-expired /
# admin-created / CA-bootstrap push notifications. No-op when either unset.
#   Bot token: @BotFather
#   Chat id: @userinfobot (PM) or -100... (group)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ───── Tier-1: Geo-block + honeypot (cycle #6) ─────
# CSV of ISO 3166-1 alpha-2 country codes allowed on /api/* (admin paths).
# Empty = disabled. Requires Cloudflare orange-cloud + CF-IPCountry header;
# without that an attacker can spoof the header. Public surfaces (/sub/,
# /api/internal/, /health) bypass this check.
ADMIN_ALLOWED_COUNTRIES=

# Honeypot scanner-trap blacklist TTL (seconds). 3600 = 1h is the default —
# long enough to wear a scanner down, short enough that legit users on
# shared CGNAT aren't permanently locked out.
HONEYPOT_BLACKLIST_TTL_SEC=3600

# Honey subscription tokens (CSV). Tokens admin plants in suspicious channels
# as a leak tripwire — any hit on /sub/<honey> fires a Telegram alert and
# blacklists the source IP. Never matches a real user.
HONEY_USER_TOKENS=

# ============================================================================
# Frontend
# ============================================================================
# Empty = relative requests that the frontend nginx proxies to backend.
# Set explicitly only if you serve the frontend from a different origin.
VITE_API_BASE_URL=

# Host port the frontend listens on (mapped to container :80).
# Behind Caddy/nginx-on-host, leave at 8080 and reverse-proxy to it.
FRONTEND_PORT=8080
