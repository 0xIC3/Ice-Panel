NODE_ENV=development

APP_PORT=3000
APP_HOST=0.0.0.0

DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME

LOG_LEVEL=info

JWT_SECRET=

REDIS_URL=redis://localhost:16379

# Public Hysteria2 UDP port advertised in subscription URIs.
# 443 by default — node operators usually run hysteria on :443/UDP.
HYSTERIA_PUBLIC_PORT=443

# Comma-separated list of frontend origins allowed to call the API.
# Production: set this to your admin UI domain (e.g. https://panel.example.com).
CORS_ORIGIN=http://localhost:5173